[Unit]
Description=Robot dog SANA-WM streaming service
After=network.target

[Service]
Type=simple
User=asus
WorkingDirectory=/home/asus/robot-dog-3d-analysis
EnvironmentFile=-/home/asus/robot-dog-3d-analysis/.env
ExecStart=/home/asus/robot-dog-3d-analysis/scripts/run.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
