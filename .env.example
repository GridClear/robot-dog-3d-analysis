# Splat service (env prefix SPLAT_)
SPLAT_HOST=0.0.0.0
SPLAT_PORT=8090
SPLAT_DATA_DIR=data

# Frame limits
SPLAT_MIN_FRAMES=3
SPLAT_MAX_FRAMES=120
SPLAT_VIDEO_FPS=3

# Backends (vggt | mast3r)
SPLAT_POSE_BACKEND=vggt
SPLAT_TRAIN_BACKEND=gsplat

# Training (per-scene optimization, not pretrained weights)
SPLAT_TRAIN_ITERATIONS=7000
SPLAT_DATA_FACTOR=2
SPLAT_TEST_EVERY=8

# VRAM: stop heavy GPU consumers before training if OOM
#   sudo systemctl stop ollama
