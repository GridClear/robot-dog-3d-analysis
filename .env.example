# World-model service (env prefix WM_)
WM_HOST=0.0.0.0
WM_PORT=8090
WM_DATA_DIR=data

# Production cadence: min seconds between starting each image (set from benchmark on Spark)
WM_INTERVAL_SEC=30

# Clip: num_frames / fps <= 60
WM_NUM_FRAMES=321
WM_FPS=16
WM_MAX_CLIP_SECONDS=60

# Quality vs speed (bidirectional release; use benchmark to tune)
WM_USE_REFINER=false
# Optional: skip Pi3X per frame (demo intrinsics used if unset and demo file exists)
# WM_DEFAULT_INTRINSICS=third_party/Sana/asset/sana_wm/demo_0_intrinsics.npy
WM_INFERENCE_STEP=60
WM_OFFLOAD_VAE=false
WM_OFFLOAD_REFINER=false

# Enable when NVlabs ships distilled NVFP4 inference flags
WM_NVFP4_ENABLED=false

# Default camera motion preset (see app/motion_presets.py)
WM_ACTION_PRESET=forward_explore
WM_TRANSLATION_SPEED=0.055
WM_ROTATION_SPEED_DEG=1.2

WM_SANA_CONDA_ENV=sana
WM_SANA_REPO=third_party/Sana
WM_INFERENCE_TIMEOUT_SEC=3600
